---
import "../styles/global.css";

import NavBar from "../components/NavBar.astro";
import Footer from "../components/Footer.astro";
import ProductCard from "../components/ProductCard.astro";
import Parallaxsection from "../components/Parallaxsection.astro";
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TITANFLOW</title>
  </head>

  <body>

    <NavBar />

    <!-- HERO VIDEO -->
    <section class="hero">

      <video autoplay muted loop playsinline class="bg-video">
        <source src="/img/TITANFLOW.mp4" type="video/mp4" />
      </video>

      <div class="hero-overlay"></div>

      <div class="hero-content">
        <h1 class="hero-title">TITANFLOW</h1>

        <a href="#products" class="hero-btn">
          Explorar productos
        </a>
      </div>

    </section>

    <!-- PRODUCTOS -->
    <section class="container" id="products">

      <h1 class="title">TITANFLOW CLASSIC</h1>

      <div class="products">

        <ProductCard
          name="TitanFlow Classic Grey"
          imgBase="TitanFlow-ClassicGrey"
          alt="TitanFlow Classic Grey"
          slug="classic-grey"
        />

        <ProductCard
          name="TitanFlow Classic Yellow"
          imgBase="TitanFlow-ClassicYellow"
          alt="TitanFlow Classic Yellow"
          slug="classic-yellow"
        />

        <ProductCard
          name="TitanFlow Morango"
          imgBase="TitanFlow-Morango"
          alt="TitanFlow Morango"
          slug="morango"
        />

        <ProductCard
          name="TitanFlow Performance"
          imgBase="TitanFlow-Performance"
          alt="TitanFlow Performance"
          slug="performance"
        />

        <ProductCard
          name="TitanFlow BlueBerry"
          imgBase="TitanFlow-Blueberry"
          alt="TitanFlow BlueBerry"
          slug="blueberry"
        />

        <ProductCard
          name="TitanFlow Thorns Crown"
          imgBase="TitanFlow-Thorns-Crown"
          alt="TitanFlow Thorns Crown"
          slug="thorns-crown"
        />

      </div>

    </section>

    <!-- PARALLAX -->
    <Parallaxsection
      title="ENERGÍA SIN LÍMITES"
      subtitle="La nueva generación de bebidas deportivas"
    />

    <!-- BENEFICIOS -->
    <section class="benefits">

      <div class="benefit-card">
        <h2>Creatina Premium</h2>
        <p>
          Potencia tu fuerza y recuperación muscular.
        </p>
      </div>

      <div class="benefit-card">
        <h2>Electrolitos</h2>
        <p>
          Mantén una hidratación perfecta durante el entrenamiento.
        </p>
      </div>

      <div class="benefit-card">
        <h2>Máximo Rendimiento</h2>
        <p>
          Diseñado para atletas y deportistas exigentes.
        </p>
      </div>

    </section>

    <Footer />

  </body>
</html>